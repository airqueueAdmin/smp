VITE_APPS_IN_TOSS_APP_NAME=summer-ping
VITE_REMINDER_API_BASE_URL=https://your-reminder-server.example.com
VITE_SMART_MESSAGE_TEMPLATE_CODE=summer-ping-reapply
VITE_USER_NAME_CONSENTED_DATA_KEY=cud_your_user_name_key

APPS_IN_TOSS_APP_NAME=summer-ping
SMART_MESSAGE_TEMPLATE_SET_CODE=summer-ping-reapply
SMART_MESSAGE_TEST_DEPLOYMENT_ID=replace-with-latest-deployment-id
SMART_MESSAGE_DEBUG_ENDPOINTS=false
SMART_MESSAGE_STORE_DIR=/persistent-volume/summer-ping
ALLOWED_ORIGINS=http://localhost:5173,https://summer-ping.private-apps.tossmini.com,https://summer-ping.apps.tossmini.com

APPS_IN_TOSS_CERT_PATH=/absolute/path/to/your/cert.pem
APPS_IN_TOSS_KEY_PATH=/absolute/path/to/your/key.pem
APPS_IN_TOSS_USER_INFO_DECRYPTION_KEY=replace-with-your-32-byte-key
APPS_IN_TOSS_USER_INFO_AAD=replace-with-your-aad
